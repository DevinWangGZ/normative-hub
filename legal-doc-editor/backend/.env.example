# ==========================================
# Legal Doc Editor - 后端环境变量配置
# 复制此文件为 .env 并修改为你自己的配置
# ==========================================

# ------------------------------------------
# 数据库配置 (MySQL)
# 格式: mysql+aiomysql://用户名:密码@主机:端口/数据库名
# ------------------------------------------
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/legaldoc

# ------------------------------------------
# Redis 缓存 (可选)
# 留空则不使用 Redis，使用本地内存缓存
# 格式: redis://主机:端口/数据库号
# ------------------------------------------
REDIS_URL=
# REDIS_URL=redis://localhost:6379/0

# ------------------------------------------
# 安全密钥
# 生产环境请使用强随机字符串
# 生成命令: openssl rand -hex 32
# ------------------------------------------
SECRET_KEY=your-secret-key-change-in-production

# ------------------------------------------
# Token 过期时间 (分钟)
# 默认 7 天
# ------------------------------------------
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ------------------------------------------
# 运行环境
# development | production | testing
# ------------------------------------------
ENVIRONMENT=development

# ------------------------------------------
# CORS 允许的前端地址 (开发环境)
# 多个地址用逗号分隔
# ------------------------------------------
ALLOWED_HOSTS=http://localhost:3001,http://localhost:5173
